{
  "name": "@laplace.live/event-bridge-sdk",
  "description": "LAPLACE Event Bridge SDK",
  "version": "1.0.24",
  "module": "index.ts",
  "types": "index.ts",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/laplace-live/event-bridge.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://chat.laplace.live",
  "scripts": {
    "build": "bun build index.ts --outdir dist --target browser --minify",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./index.ts"
    }
  },
  "files": [
    "dist",
    "index.ts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@laplace.live/event-types": "^2.0.18"
  },
  "devDependencies": {
    "bun-types": "latest"
  }
}
